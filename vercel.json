{
  "rewrites": [{"source": "/((?!api/).*)", "destination": "/index.html"}],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate"},
        {"key": "Pragma", "value": "no-cache"},
        {"key": "Expires", "value": "0"}
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate"},
        {"key": "Pragma", "value": "no-cache"},
        {"key": "Expires", "value": "0"}
      ]
    },
    {
      "source": "/(.*\\.(js|css|json))",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate"},
        {"key": "Pragma", "value": "no-cache"}
      ]
    }
  ]
}
